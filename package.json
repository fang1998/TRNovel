{
  "name": "trnovel-distribution",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "npm:sync-version": "node ./scripts/sync-npm-version.mjs",
    "npm:sync-public-metadata": "node ./scripts/sync-public-metadata.mjs",
    "npm:sync-all": "npm run npm:sync-version && npm run npm:sync-public-metadata",
